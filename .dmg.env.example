# .dmg.env — credentials for `task dmg` (signed + notarized DMG build).
#
# Copy this file to .dmg.env at the repo root and fill in your values:
#   cp .dmg.env.example .dmg.env
#
# .dmg.env is gitignored — never commit real credentials. scripts/build-dmg.sh
# sources it automatically, so `task dmg` and `scripts/build-dmg.sh --preflight`
# work without exporting anything in your shell.

# Apple ID email used for notarization (your Apple Developer account).
APPLE_ID="you@example.com"

# 10-character team identifier.
# Find it: https://developer.apple.com/account -> Membership details -> Team ID.
APPLE_TEAM_ID="A1B2C3D4E5"

# Full signing-identity common name, including the "(TEAMID)" suffix.
# 1. Create a "Developer ID Application" certificate:
#    Xcode -> Settings -> Accounts -> (your Apple ID) -> Manage Certificates...
#    -> + -> Developer ID Application. It installs into your login keychain.
# 2. Read the exact name back:
#    security find-identity -v -p codesigning
#    Copy the quoted string verbatim.
DEVELOPER_ID_APPLICATION="Developer ID Application: Your Name (A1B2C3D4E5)"

# App-specific password for notarization (format: abcd-efgh-ijkl-mnop).
# Generate it: https://account.apple.com -> Sign-In and Security
#   -> App-Specific Passwords -> +. Shown only once; revoke + regenerate if lost.
APPLE_APP_SPECIFIC_PASSWORD="abcd-efgh-ijkl-mnop"
