<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  TrafficWand is intentionally NON-sandboxed (Developer ID distribution).
	  App Sandbox is disabled so the app can:
	    - read other browsers' profile config under ~/Library/Application Support
	      (Chrome "Local State", Firefox "profiles.ini"), and
	    - launch target browsers with profile/URL launch arguments.
	  These would otherwise require sandbox exceptions we deliberately avoid.
	-->
	<key>com.apple.security.app-sandbox</key>
	<false/>

	<!--
	  No com.apple.security.cs.allow-* entitlement is required for the launch
	  mechanism: spawning subprocesses (/usr/bin/open or a browser binary) from a
	  Hardened-Runtime app is allowed without any allow-* key (the allow-* family
	  governs loading code into *our* process, not spawning others). See
	  docs/spikes/launch-mechanism.md §6.
	-->
</dict>
</plist>
